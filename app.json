{
  "expo": {
    "name": "Dumbys",
    "slug": "dumbys",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Dumbys-avatar.png",
    "scheme": "dumbys",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/Dumbys-avatar.png",
      "resizeMode": "contain",
      "backgroundColor": "#080F0F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dumbys.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Dumbys-avatar.png",
        "backgroundColor": "#080F0F"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f4455fe-b529-4991-872c-dd480fea101e"
      }
    },
    "owner": "cl3ment"
  }
}
